# Monday.com API token (read/write to board 18410804557)
# Get yours from: monday.com > Admin > API
# For production: set as GitHub secret VITE_MONDAY_API_TOKEN
VITE_MONDAY_API_TOKEN=

# Google Maps / Places API key (address autocomplete)
# Get yours from: console.cloud.google.com > APIs & Services > Credentials
# For production: set as GitHub secret VITE_GOOGLE_MAPS_API_KEY
VITE_GOOGLE_MAPS_API_KEY=
